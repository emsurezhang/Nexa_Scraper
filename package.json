{
  "name": "nexa-scraper",
  "version": "3.1.0",
  "description": "基于 Playwright 的模块化、可扩展网页抓取框架",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "nexa": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "server:start": "node dist/cli/index.js server start",
    "server:stop": "node dist/cli/index.js server stop",
    "test": "vitest",
    "lint": "eslint src/ --ext .ts",
    "db:init": "node dist/core/db-init.js"
  },
  "keywords": [
    "scraper",
    "playwright",
    "crawler",
    "browser-automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "config": "^3.3.11",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.0",
    "fs-extra": "^11.2.0",
    "jsdom": "^29.0.2",
    "mime-types": "^2.1.35",
    "p-queue": "^8.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "playwright": "^1.42.0",
    "uuid": "^9.0.0",
    "yaml": "^2.4.0",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/config": "^3.3.3",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
